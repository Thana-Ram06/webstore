rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isApproved() {
      return resource.data.status == 'approved';
    }

    function hasValidTimestamps() {
      return request.resource.data.createdAt == request.time
          || request.resource.data.keys().hasAll(['createdAt', 'updatedAt']);
    }

    // ── Users ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Apps ──────────────────────────────────────────────────────────
    match /apps/{appId} {
      // Anyone can read approved apps; admins and owners see all statuses
      allow read: if isApproved() || isAdmin() || isOwner(resource.data.submittedBy);

      // Signed-in users can submit (pending status only)
      allow create: if isSignedIn()
        && request.resource.data.status == 'pending'
        && request.resource.data.submittedBy == request.auth.uid;

      // Owner can edit or soft-delete their pending app; admins can update any
      allow update: if (isOwner(resource.data.submittedBy)
          && resource.data.status == 'pending'
          && (request.resource.data.status == 'pending'
              || request.resource.data.status == 'deleted'))
        || isAdmin();

      allow delete: if isAdmin();
    }

    // ── Audit logs ────────────────────────────────────────────────────────
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ── Reviews ───────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5;

      // Only owner can update; admins can delete abusive reviews
      allow update: if isOwner(resource.data.userId);
      allow delete: if isOwner(resource.data.userId) || isAdmin();
    }

    // ── Review votes ──────────────────────────────────────────────────
    match /reviewVotes/{voteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
    }

    // ── Favorites ────────────────────────────────────────────────────
    match /favorites/{favoriteId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isOwner(resource.data.userId);
      allow update: if false;
    }
  }
}
